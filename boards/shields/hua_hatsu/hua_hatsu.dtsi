#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
	chosen {
        zephyr,display = &oled;
		zmk,kscan = &kscan0;
		zmk,matrix_transform = &default_transform;
		zmk,physical-layout = <&hua_hatsu_layout>;  // 引入物理布局
	};

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <12>;
		rows = <5>;
		map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)    RC(0,6)  RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)    RC(1,6)  RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)    RC(2,6)  RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
            RC(3,2) RC(3,3) RC(3,4) RC(3,5)    RC(3,6)  RC(3,7) RC(3,8) RC(3,9) 
            RC(4,2) RC(4,3) RC(4,4) RC(4,5)    RC(4,6)  RC(4,7) RC(4,8) RC(4,9) 
		>;
	};

// ===================== 物理布局 =====================
hua_hatsu_layout: hua_hatsu_layout {
	compatible = "zmk,physical-layout";
	display-name = "Hua_Hatsu";
	keys
		// 第1行
		= <&key_physical_attrs 100 100   0   0   0 0 0>
		, <&key_physical_attrs 100 100 110   0   0 0 0>
		, <&key_physical_attrs 100 100 220   0   0 0 0>
		, <&key_physical_attrs 100 100 330   0   0 0 0>
		, <&key_physical_attrs 100 100 440   0   0 0 0>
		, <&key_physical_attrs 100 100 550   0   0 0 0>
		, <&key_physical_attrs 100 100 770   0   0 0 0>
		, <&key_physical_attrs 100 100 880   0   0 0 0>
		, <&key_physical_attrs 100 100 990   0   0 0 0>
		, <&key_physical_attrs 100 100 1100  0   0 0 0>
		, <&key_physical_attrs 100 100 1210  0   0 0 0>
		, <&key_physical_attrs 100 100 1320  0   0 0 0>
		// 第2行
		, <&key_physical_attrs 100 100   0 110   0 0 0>
		, <&key_physical_attrs 100 100 110 110   0 0 0>
		, <&key_physical_attrs 100 100 220 110   0 0 0>
		, <&key_physical_attrs 100 100 330 110   0 0 0>
		, <&key_physical_attrs 100 100 440 110   0 0 0>
		, <&key_physical_attrs 100 100 550 110   0 0 0>
		, <&key_physical_attrs 100 100 770 110   0 0 0>
		, <&key_physical_attrs 100 100 880 110   0 0 0>
		, <&key_physical_attrs 100 100 990 110   0 0 0>
		, <&key_physical_attrs 100 100 1100 110   0 0 0>
		, <&key_physical_attrs 100 100 1210 110   0 0 0>
		, <&key_physical_attrs 100 100 1320 110   0 0 0>
		// 第3行
		, <&key_physical_attrs 100 100   0 220   0 0 0>
		, <&key_physical_attrs 100 100 110 220   0 0 0>
		, <&key_physical_attrs 100 100 220 220   0 0 0>
		, <&key_physical_attrs 100 100 330 220   0 0 0>
		, <&key_physical_attrs 100 100 440 220   0 0 0>
		, <&key_physical_attrs 100 100 550 220   0 0 0>
		, <&key_physical_attrs 100 100 770 220   0 0 0>
		, <&key_physical_attrs 100 100 880 220   0 0 0>
		, <&key_physical_attrs 100 100 990 220   0 0 0>
		, <&key_physical_attrs 100 100 1100 220   0 0 0>
		, <&key_physical_attrs 100 100 1210 220   0 0 0>
		, <&key_physical_attrs 100 100 1320 220   0 0 0>
		// 第4行
		, <&key_physical_attrs 100 100 330 330   0 0 0>
		, <&key_physical_attrs 100 100 440 330   0 0 0>
		, <&key_physical_attrs 100 100 550 330   0 0 0>
		, <&key_physical_attrs 100 100 770 330   0 0 0>
		, <&key_physical_attrs 100 100 880 330   0 0 0>
		, <&key_physical_attrs 100 100 990 330   0 0 0>
		// 第5行
		, <&key_physical_attrs 100 100 330 440   0 0 0>
		, <&key_physical_attrs 100 100 440 440   0 0 0>
		, <&key_physical_attrs 100 100 550 440   0 0 0>
		, <&key_physical_attrs 100 100 770 440   0 0 0>
		, <&key_physical_attrs 100 100 880 440   0 0 0>
		, <&key_physical_attrs 100 100 990 440   0 0 0>
	;
};

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		diode-direction = "row2col";
		physical-layout = <&hua_hatsu_layout>;

		row-gpios
        = <&pro_micro 7 GPIO_ACTIVE_HIGH> // Row A from the schematic file
        , <&pro_micro 8 GPIO_ACTIVE_HIGH> // Row B from the schematic file
        , <&pro_micro 9 GPIO_ACTIVE_HIGH> // Row C from the schematic file
        , <&pro_micro 21 GPIO_ACTIVE_HIGH> // Row D from the schematic file
        , <&pro_micro 20 GPIO_ACTIVE_HIGH> // Row E from the schematic file
        ;
	};

};

&pro_micro_i2c {
    status = "okay";

    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <32>;
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <31>;
        segment-remap;
        com-invdir;
        com-sequential;
        inversion-on;
        prechargep = <0x22>;
    };
};
