#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
	chosen {
        zephyr,display = &oled;
		zmk,kscan = &kscan0;
		zmk,physical-layout = &hua_hatsu_layout;  // 引入物理布局
	};

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <12>;
		rows = <5>;
		map = <
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)    RC(0,6)  RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)    RC(1,6)  RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)    RC(2,6)  RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
                    RC(3,2) RC(3,3) RC(3,4) RC(3,5)    RC(3,6)  RC(3,7) RC(3,8) RC(3,9) 
                    RC(4,2) RC(4,3) RC(4,4) RC(4,5)    RC(4,6)  RC(4,7) RC(4,8) RC(4,9) 
		>;
	};

    // ===================== 物理布局 =====================
    hua_hatsu_layout: hua_hatsu_layout {
        compatible = "zmk,physical-layout";
        transform = <&default_transform>;
        display-name = "Hua_Hatsu_Layout";
         keys  //                     w   h    x    y     rot    rx    ry
            // 第一行  
            = <&key_physical_attrs 100 100    0   36       0     0     0>
            , <&key_physical_attrs 100 100  100   36       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   11       0     0     0>
            , <&key_physical_attrs 100 100  500   11       0     0     0>
            , <&key_physical_attrs 100 100 1000   11       0     0     0>
            , <&key_physical_attrs 100 100 1100   11       0     0     0>
            , <&key_physical_attrs 100 100 1200    0       0     0     0>
            , <&key_physical_attrs 100 100 1300    0       0     0     0>
            , <&key_physical_attrs 100 100 1400   36       0     0     0>
            , <&key_physical_attrs 100 100 1500   36       0     0     0>
            // 第二行  
            , <&key_physical_attrs 100 100    0  136       0     0     0>
            , <&key_physical_attrs 100 100  100  136       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  111       0     0     0>
            , <&key_physical_attrs 100 100  500  111       0     0     0>
            , <&key_physical_attrs 100 100 1000  111       0     0     0>
            , <&key_physical_attrs 100 100 1100  111       0     0     0>
            , <&key_physical_attrs 100 100 1200  100       0     0     0>
            , <&key_physical_attrs 100 100 1300  100       0     0     0>
            , <&key_physical_attrs 100 100 1400  136       0     0     0>
            , <&key_physical_attrs 100 100 1500  136       0     0     0>
            // 第三行  
            , <&key_physical_attrs 100 100    0  236       0     0     0>
            , <&key_physical_attrs 100 100  100  236       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  211       0     0     0>
            , <&key_physical_attrs 100 100  500  211       0     0     0>
            , <&key_physical_attrs 100 100 1000  211       0     0     0>
            , <&key_physical_attrs 100 100 1100  211       0     0     0>
            , <&key_physical_attrs 100 100 1200  200       0     0     0>
            , <&key_physical_attrs 100 100 1300  200       0     0     0>
            , <&key_physical_attrs 100 100 1400  236       0     0     0>
            , <&key_physical_attrs 100 100 1500  236       0     0     0>
            // 第四行
            , <&key_physical_attrs 100 100  200  300       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 100 150  412  345    1400     0     0>
            , <&key_physical_attrs 100 150  512  345    1400     0     0>
            , <&key_physical_attrs 100 150  992  370 (-1400)     0     0>
            , <&key_physical_attrs 100 150 1092  370 (-1400)     0     0>
            , <&key_physical_attrs 100 100 1200  300       0     0     0>
            , <&key_physical_attrs 100 100 1300  300       0     0     0>
            // 第五/六行 左边
            , <&key_physical_attrs 100 100  565  645    6500     0     0>
            , <&key_physical_attrs 100 100  535  545    6500     0     0>
            , <&key_physical_attrs 100 100  635  500    6500     0     0>
            , <&key_physical_attrs 100 100  665  600    6500     0     0>
            // 第五/六行 右边
            , <&key_physical_attrs 100 100  900  690 (-6500)     0     0>
            , <&key_physical_attrs 100 100  930  590 (-6500)     0     0>
            , <&key_physical_attrs 100 100 1030  630 (-6500)     0     0>
            , <&key_physical_attrs 100 100 1000  735 (-6500)     0     0>
            ;
    };

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		diode-direction = "row2col";

		row-gpios
        = <&pro_micro 7 GPIO_ACTIVE_HIGH> // Row A from the schematic file
        , <&pro_micro 8 GPIO_ACTIVE_HIGH> // Row B from the schematic file
        , <&pro_micro 9 GPIO_ACTIVE_HIGH> // Row C from the schematic file
        , <&pro_micro 21 GPIO_ACTIVE_HIGH> // Row D from the schematic file
        , <&pro_micro 20 GPIO_ACTIVE_HIGH> // Row E from the schematic file
        ;
	};

};

&pro_micro_i2c {
    status = "okay";

    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <32>;
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <31>;
        segment-remap;
        com-invdir;
        com-sequential;
        inversion-on;
        prechargep = <0x22>;
    };
};
